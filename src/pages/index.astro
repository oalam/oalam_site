---
import Layout from '../layouts/Layout.astro';
---

<Layout>

<!-- ══════════════════════════════════════
     NAV FIXE
══════════════════════════════════════ -->
<header id="top">
  <nav class="nav">
    <div class="container nav__inner">
      <a href="#top" class="nav__logo">L'Octet à la Menthe</a>
      <ul class="nav__links">
        <li><a href="#profil">Profil</a></li>
        <li><a href="#mission">Mission</a></li>
        <li><a href="#expertises">Expertises</a></li>
        <li><a href="#contact" class="nav__cta">Contact</a></li>
      </ul>
      <button class="nav__burger" aria-label="Menu" onclick="document.querySelector('.nav__links').classList.toggle('open')">
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</header>


<!-- ══════════════════════════════════════
     HERO
══════════════════════════════════════ -->
<section class="hero">
  <div class="container hero__inner">
    <div class="hero__content fade-up" style="animation-delay:0.1s">
      <p class="section-label">Drôme · AuRA · Remote</p>
      <h1 class="hero__title">Consultant<br/><span class="hero__accent">Data & IA</span></h1>
      <p class="hero__sub">
        J'aide les PME et ETI à exploiter leurs données avec une IA <strong>frugale, souveraine et humaine</strong> — de l'audit initial à la feuille de route opérationnelle.
      </p>
      <div class="hero__tags">
        <span class="tag">12 ans d'expérience</span>
        <span class="tag">50+ jours de formation</span>
        <span class="tag">Auteur ENI</span>
      </div>
      <div class="hero__actions">
        <a href="#contact" class="btn btn--primary">Parlons de votre projet</a>
        <a href="#mission" class="btn btn--outline">Voir le processus</a>
      </div>
    </div>
    <div class="hero__visual fade-up" style="animation-delay:0.3s" aria-hidden="true">
      <!-- Illustration paysage Drôme / Diois — collines, Vercors, vignes, data overlay -->
      <svg viewBox="0 0 440 380" xmlns="http://www.w3.org/2000/svg" class="hero__svg">
        <defs>
          <clipPath id="card-clip">
            <rect x="0" y="0" width="440" height="380" rx="24"/>
          </clipPath>
          <!-- Gradient ciel -->
          <linearGradient id="sky" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#d4ecd4"/>
            <stop offset="100%" stop-color="#f0f9f0"/>
          </linearGradient>
          <!-- Gradient montagnes -->
          <linearGradient id="mtn1" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#4a7c5a"/>
            <stop offset="100%" stop-color="#2e5438"/>
          </linearGradient>
          <linearGradient id="mtn2" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#6aaa7e"/>
            <stop offset="100%" stop-color="#3a6b47"/>
          </linearGradient>
          <linearGradient id="hill1" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#8dc99a"/>
            <stop offset="100%" stop-color="#5a9a6a"/>
          </linearGradient>
          <linearGradient id="valley" x1="0" y1="0" x2="0" y2="1">
            <stop offset="0%" stop-color="#b8e0c0"/>
            <stop offset="100%" stop-color="#8dc99a"/>
          </linearGradient>
        </defs>

        <g clip-path="url(#card-clip)">

          <!-- Fond ciel -->
          <rect width="440" height="380" fill="url(#sky)"/>

          <!-- Soleil levant -->
          <circle cx="340" cy="80" r="38" fill="#f9d67a" opacity="0.55"/>
          <circle cx="340" cy="80" r="28" fill="#f7c94a" opacity="0.7"/>

          <!-- Vercors / Massif arrière-plan -->
          <path d="M-10 220 L40 140 L80 170 L120 110 L160 145 L200 95 L240 130 L280 105 L320 138 L360 115 L400 145 L440 120 L450 220 Z"
                fill="url(#mtn1)" opacity="0.85"/>

          <!-- Neige sommet Vercors -->
          <path d="M195 97 L200 95 L205 97 L210 110 L200 108 L190 110 Z" fill="white" opacity="0.8"/>
          <path d="M278 107 L284 105 L290 108 L286 118 L280 116 Z" fill="white" opacity="0.75"/>

          <!-- Chaîne intermédiaire -->
          <path d="M-10 260 L30 195 L70 215 L110 185 L150 205 L200 175 L250 200 L290 180 L340 200 L390 182 L440 200 L450 260 Z"
                fill="url(#mtn2)" opacity="0.9"/>

          <!-- Colline principale gauche -->
          <path d="M-10 310 Q60 240 140 258 Q200 265 240 285 L240 380 L-10 380 Z"
                fill="url(#hill1)"/>

          <!-- Colline droite / fond vallée Diois -->
          <path d="M220 300 Q300 255 380 270 Q420 278 450 290 L450 380 L220 380 Z"
                fill="url(#hill1)" opacity="0.9"/>

          <!-- Fond de vallée -->
          <path d="M100 340 Q180 308 260 318 Q330 326 420 315 L440 380 L80 380 Z"
                fill="url(#valley)"/>

          <!-- Vignes stylisées (rangées) — inspiration Clairette de Die -->
          <g opacity="0.7">
            <!-- Rangée 1 -->
            <line x1="110" y1="335" x2="200" y2="328" stroke="#2e5438" stroke-width="1.5"/>
            <line x1="110" y1="342" x2="200" y2="335" stroke="#2e5438" stroke-width="1.5"/>
            <line x1="110" y1="349" x2="200" y2="342" stroke="#2e5438" stroke-width="1.5"/>
            <!-- Piquets vigne -->
            <line x1="125" y1="330" x2="125" y2="355" stroke="#5a3a1a" stroke-width="1.5" opacity="0.6"/>
            <line x1="150" y1="328" x2="150" y2="352" stroke="#5a3a1a" stroke-width="1.5" opacity="0.6"/>
            <line x1="175" y1="326" x2="175" y2="350" stroke="#5a3a1a" stroke-width="1.5" opacity="0.6"/>
            <!-- Rangée 2 -->
            <line x1="240" y1="325" x2="380" y2="318" stroke="#2e5438" stroke-width="1.5"/>
            <line x1="240" y1="332" x2="380" y2="325" stroke="#2e5438" stroke-width="1.5"/>
            <line x1="240" y1="339" x2="380" y2="332" stroke="#2e5438" stroke-width="1.5"/>
            <line x1="270" y1="320" x2="270" y2="342" stroke="#5a3a1a" stroke-width="1.5" opacity="0.6"/>
            <line x1="310" y1="318" x2="310" y2="340" stroke="#5a3a1a" stroke-width="1.5" opacity="0.6"/>
            <line x1="350" y1="316" x2="350" y2="338" stroke="#5a3a1a" stroke-width="1.5" opacity="0.6"/>
          </g>

          <!-- Grappes de raisin stylisées -->
          <g fill="#7b4a9e" opacity="0.55">
            <circle cx="127" cy="325" r="3"/>
            <circle cx="131" cy="321" r="2.5"/>
            <circle cx="123" cy="321" r="2.5"/>
            <circle cx="127" cy="317" r="2"/>
          </g>
          <g fill="#7b4a9e" opacity="0.5">
            <circle cx="312" cy="313" r="3"/>
            <circle cx="316" cy="309" r="2.5"/>
            <circle cx="308" cy="309" r="2.5"/>
            <circle cx="312" cy="305" r="2"/>
          </g>

          <!-- Rivière (la Drôme) -->
          <path d="M-10 365 Q80 355 160 362 Q240 369 320 358 Q380 350 450 360"
                fill="none" stroke="#7ab8d4" stroke-width="4" opacity="0.6"/>
          <path d="M-10 370 Q80 360 160 367 Q240 374 320 363 Q380 355 450 365"
                fill="none" stroke="#7ab8d4" stroke-width="2.5" opacity="0.35"/>

          <!-- Oiseau (hirondelle stylisée) -->
          <path d="M340 155 Q348 150 356 155 Q348 158 340 155Z" fill="#2e5438" opacity="0.6"/>
          <path d="M372 145 Q380 140 388 145 Q380 148 372 145Z" fill="#2e5438" opacity="0.5"/>

          <!-- DATA OVERLAY : nœuds et connexions flottants sur le paysage -->
          <!-- Connexions réseau -->
          <line x1="80" y1="170" x2="160" y2="200" stroke="#e8965a" stroke-width="1.5" opacity="0.5" stroke-dasharray="4 3"/>
          <line x1="160" y1="200" x2="260" y2="185" stroke="#e8965a" stroke-width="1.5" opacity="0.5" stroke-dasharray="4 3"/>
          <line x1="260" y1="185" x2="340" y2="210" stroke="#e8965a" stroke-width="1.5" opacity="0.4" stroke-dasharray="4 3"/>
          <line x1="160" y1="200" x2="200" y2="265" stroke="#3a6b47" stroke-width="1" opacity="0.35" stroke-dasharray="3 4"/>
          <line x1="260" y1="185" x2="290" y2="262" stroke="#3a6b47" stroke-width="1" opacity="0.35" stroke-dasharray="3 4"/>

          <!-- Nœuds données -->
          <circle cx="80" cy="170" r="7" fill="#fefdf8" stroke="#e8965a" stroke-width="2"/>
          <circle cx="80" cy="170" r="3" fill="#e8965a"/>

          <circle cx="160" cy="200" r="9" fill="#fefdf8" stroke="#3a6b47" stroke-width="2.5"/>
          <circle cx="160" cy="200" r="4" fill="#3a6b47"/>

          <circle cx="260" cy="185" r="7" fill="#fefdf8" stroke="#e8965a" stroke-width="2"/>
          <circle cx="260" cy="185" r="3" fill="#e8965a"/>

          <circle cx="340" cy="210" r="6" fill="#fefdf8" stroke="#3a6b47" stroke-width="2"/>
          <circle cx="340" cy="210" r="2.5" fill="#3a6b47"/>

          <!-- Badge "Data" central -->
          <rect x="138" y="213" width="48" height="22" rx="11" fill="#3a6b47"/>
          <text x="162" y="228" font-family="sans-serif" font-size="9" font-weight="bold" fill="white" text-anchor="middle">DATA</text>

          <!-- Badge "IA" -->
          <rect x="242" y="195" width="36" height="20" rx="10" fill="#e8965a"/>
          <text x="260" y="209" font-family="sans-serif" font-size="9" font-weight="bold" fill="white" text-anchor="middle">IA</text>

          <!-- Indicateur signal -->
          <g opacity="0.7">
            <circle cx="370" cy="170" r="12" fill="none" stroke="#e8965a" stroke-width="1.5" opacity="0.3"/>
            <circle cx="370" cy="170" r="7" fill="none" stroke="#e8965a" stroke-width="1.5" opacity="0.5"/>
            <circle cx="370" cy="170" r="3" fill="#e8965a"/>
          </g>
          <line x1="340" y1="210" x2="370" y2="170" stroke="#e8965a" stroke-width="1" opacity="0.3" stroke-dasharray="3 3"/>

        </g>
      </svg>
    </div>
  </div>
</section>

<!-- Séparateur vague hero → profil -->
<div class="wave-sep" aria-hidden="true">
  <svg viewBox="0 0 1440 64" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
    <path d="M0 0 Q360 64 720 32 Q1080 0 1440 48 L1440 64 L0 64 Z" fill="#f0f4ee"/>
  </svg>
</div>

<!-- ══════════════════════════════════════
     PROFIL / À PROPOS
══════════════════════════════════════ -->
<section id="profil" class="section section--alt" style="padding-top:2rem">
  <div class="container">
    <p class="section-label">À propos</p>
    <h2 class="section-title">12 ans au service de la donnée industrielle</h2>
    <div class="profil__grid">
      <div class="profil__text">
        <p>
          Fondateur de <strong>L'Octet à la Menthe</strong> à Die et Grenoble, j'accompagne des grands comptes (Carrefour, FDJ, IFPEN, CETIM) et des PME régionales dans leur transformation data. Mon approche associe rigueur technique — Big Data, LLM, IoT industriel — et vision stratégique orientée résultats.
        </p>
        <p>
          Membre de <strong>Minalogic</strong>, lauréat de programmes <strong>France 2030</strong>, auteur chez <strong>ENI</strong> et formateur certifié, je crois à une IA sobre, explicable et ancrée dans les réalités de terrain des PME.
        </p>
        <blockquote class="profil__quote">
          "L'IA ne vaut que si elle s'intègre dans les processus réels, avec les femmes et les hommes qui les font vivre — pas malgré eux."
        </blockquote>
      </div>
      <div class="profil__badges">

        <!-- Minalogic : circuit + colline -->
