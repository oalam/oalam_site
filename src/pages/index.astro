<!-- ══════════════════════════════════════
     PROCESSUS DE MISSION
══════════════════════════════════════ -->
<section id="mission" class="section" style="padding-top:2rem">
  <div class="container">
    <p class="section-label">Processus</p>
    <h2 class="section-title">Diag Data IA — 7 jours pour voir clair</h2>
    <p class="section-intro">Un diagnostic structuré qui transforme votre réalité terrain en feuille de route concrète et priorisée.</p>

    <div class="process__grid">
      <div class="process-card">
        <div class="process-card__num">01</div>
        <div class="process-card__content">
          <div class="process-card__icon">
            <svg width="28" height="28" viewBox="0 0 28 28" fill="none"><circle cx="14" cy="14" r="13" stroke="currentColor" stroke-width="2"/><path d="M9 14h10M14 9v10" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
