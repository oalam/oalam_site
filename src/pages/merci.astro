---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Message envoyé — L'Octet à la Menthe"
  description="Votre message a bien été envoyé."
  noindex={true}
>

<style>
  .merci {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 1.5rem;
    background: var(--bg);
  }

  .merci__icon {
    width: 72px;
    height: 72px;
    background: rgba(58,107,71,0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    color: var(--primary);
  }

  .merci__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--text);
    margin-bottom: 0.75rem;
  }

  .merci__sub {
    font-size: 1.05rem;
    color: var(--text-mute);
    max-width: 440px;
    line-height: 1.65;
    margin-bottom: 2.5rem;
  }
</style>

<div class="merci">
  <div class="merci__icon">
    <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
      <path d="M8 18l7 7L28 11" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>
  <h1 class="merci__title">Message envoyé !</h1>
  <p class="merci__sub">
    Merci pour votre message. Je vous réponds sous 24 h ouvrées.
  </p>
  <a href="/" class="btn btn--primary">Retour à l'accueil</a>
</div>

</Layout>
